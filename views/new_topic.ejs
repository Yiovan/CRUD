<%- include('./partials/header') %>

<section class="form-section animate-fade-in">
    <div class="form-container">
        <h2>Crear Nuevo Tema</h2>
        <p class="text-muted" style="margin-bottom: 2rem;">Comparte un nuevo tema de aprendizaje con la comunidad.</p>
        
        <form action="/topics" method="POST" class="custom-form">
            <div class="form-group">
                <label for="title">Título del Tema</label>
                <input type="text" id="title" name="title" required placeholder="Ej. Cómo programar como un ninja">
            </div>
            <div class="form-group">
                <label for="description">Descripción</label>
                <textarea id="description" name="description" rows="4" required placeholder="Describe brevemente de qué trata este tema..."></textarea>
            </div>
            <div class="form-actions">
                <a href="/" class="btn-outline">Cancelar</a>
                <button type="submit" class="btn-primary">Crear Tema</button>
            </div>
        </form>
    </div>
</section>

<%- include('./partials/footer') %>
